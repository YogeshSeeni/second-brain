# Copy to /etc/brain/brain-core.env and fill in.
# chmod 0640, chown root:ubuntu.

# Whoop V2 OAuth (see infra/ec2/bootstrap-day2.md for registration steps)
BRAIN_WHOOP_CLIENT_ID=
BRAIN_WHOOP_CLIENT_SECRET=
BRAIN_WHOOP_SECRET=brain/whoop_oauth

# AWS region for Secrets Manager lookups
AWS_REGION=us-west-2
