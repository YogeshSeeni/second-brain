# Copy to /etc/brain/brain-web.env and fill in.
# chmod 0640, chown root:ubuntu.
#
# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=<client id from Google Cloud Console>
AUTH_GOOGLE_SECRET=<client secret from Google Cloud Console>
AUTH_TRUST_HOST=true
AUTH_URL=https://brain-<slug>.duckdns.org

# Single-user allowlist — comma-separated
ALLOWED_EMAILS=yogesh60@stanford.edu

# Same-origin proxy: empty → use relative /api/* which Caddy routes to brain-core
NEXT_PUBLIC_BRAIN_CORE_URL=
