.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/themes/
.trash/
.DS_Store
*.swp

# Personal data — never commit (vault content lives only on local disk + EBS)
raw/
wiki/
output/

# brain-v1 EBS runtime layout — these dirs are created by cloud-init at the
# /var/brain mount root and coexist with the repo checkout. Ignoring them at
# the repo root keeps `git status` clean on the live instance.
/vault.git/
/worktrees/
/db/
/scratch/
/config/
/logs/

# Secrets — never commit
.claude/settings.json
.claude/settings.local.json
.env
.env.*
!.env.example

# Runtime artifacts
.scripts/logs/
.scripts/state/

# Terraform state + local vars
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*.tfvars
infra/terraform/*.tfplan
infra/terraform/.terraform.lock.hcl
!infra/terraform/*.tfvars.example

# Docker build artifacts
infra/docker/.build/

# Python venvs + SQLite runtime state
apps/brain-core/.venv/
apps/brain-core/db/
apps/brain-core/__pycache__/
apps/brain-core/brain_core/__pycache__/
apps/brain-core/*.egg-info/
apps/brain-core/uv.lock
**/__pycache__/
*.pyc

# Node
apps/brain-web/node_modules/
apps/brain-web/.next/
apps/brain-web/out/
apps/brain-web/.env.local
